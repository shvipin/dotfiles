source /usr/share/bash-completion/completions/git
alias ga='git add'
alias gaa='git add -A'
alias gau='git add -u'
alias gap='git add -p'
__git_complete ga _git_add
alias gb='git branch'
__git_complete gb _git_branch
alias gcln='git clean -xdfq'
alias gcs='git commit -s'
alias gca='git commit --amend'
alias gcas='git commit --amend -s'
alias gcan='git commit --amend --no-edit'
alias gcans='git commit --amend --no-edit -s'
alias gck='git checkout'
__git_complete gck _git_checkout
alias gcp='git cherry-pick'
alias gcpa='git cherry-pick --abort'
alias gcpc='git cherry-pick --continue'
alias gd='git diff'
alias gds='git diff --staged'
alias gf='${EDITOR} +/\<\<\ HEAD `git diff --name-only --relative --diff-filter=U`'
alias gg='git grep -n'
alias gl='git log'
__git_complete gl _git_log
alias gl1='git log -1'
__git_complete gl1 _git_log
alias glg='git log --grep'
__git_complete gl _git_log
alias glp='git log -p'
__git_complete glp _git_log
alias glo='git log --oneline'
__git_complete glo _git_log
alias glop='git log --pretty="%Cred%h %Cgreen%an %C(yellow)%d %Creset%s"'
__git_complete glop _git_log
alias gpr='git pull --rebase'
alias gr='git rebase'
__git_complete gr _git_rebase
alias gra='git rebase --abort'
__git_complete gra _git_rebase
alias grc='git rebase --continue'
__git_complete grc _git_rebase
alias gri='git rebase -i'
__git_complete gri _git_rebase
alias gs='git status'
alias gst='git stash'
alias gsa='git stash apply'
gsh() { git show HEAD"$1"; }
gsha() { git show "$1"; }
gwa() { git worktree add "../$1"; }
